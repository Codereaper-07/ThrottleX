PORT=3000
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
BUCKET_CAPACITY=5
REFILL_RATE=1
BUCKET_TTL=10

# Grafana admin credentials (docker-compose.yml only — read via ${VAR}
# substitution, not by the Node app). Required: docker compose will refuse
# to start Grafana if these are unset, rather than falling back to
# Grafana's own default admin/admin. Set these to your own values.
GF_SECURITY_ADMIN_USER=change_me
GF_SECURITY_ADMIN_PASSWORD=change_me_to_a_strong_password
